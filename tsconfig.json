{
  "compilerOptions": {
    "declaration": true,
    "lib": ["dom", "ESNext"],
    "module": "commonjs",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitThis": true,
    "outDir": "lib",
    "strict": false,
    "target": "es2020",
    "types": ["node", "mocha"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
